# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Local dev defaults; NOT for production.

# ── Infra passwords (dev) ──────────────────────────────────────────────
# Host port for redis publish (in-network access is always redis:6379). Override to avoid a host clash.
REDIS_HOST_PORT=6379
# Host port for postgres publish (in-network is always postgres:5432). Override to dodge host clashes.
POSTGRES_HOST_PORT=5432
DB_PASSWORD=change-me-db
REDIS_PASSWORD=change-me-redis
RABBITMQ_PASSWORD=change-me-rabbitmq
GRAFANA_PASSWORD=change-me-grafana
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak

# Config Server git (unused — config-server runs in 'native' mode locally)
GIT_USERNAME=unused
GIT_TOKEN=unused

# ── Stripe (payments, MVP) → payment-service ───────────────────────────
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# Optional. Get via `stripe listen --forward-to localhost:9080/api/payments/webhooks/stripe`.
# Unset -> webhook events ignored (payments still work; sync gRPC charge is authoritative).
STRIPE_WEBHOOK_SECRET=

# ── Razorpay (payments India, alt) → payment-service ───────────────────
RAZORPAY_KEY_ID=rzp_test_your_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── Resend (order emails, MVP) → notification-service ──────────────────
RESEND_API_KEY=re_your_key_here
RESEND_FROM=orders@example.com

# ── Twilio (order SMS) → notification-service ──────────────────────────
TWILIO_ACCOUNT_SID=ACyour_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# The Twilio phone number you own (E.164). Unset -> SMS logs instead of sending (email unaffected).
TWILIO_FROM=

# ── Cloudflare R2 / object storage (product media, prod) → product-service ──
# Local dev defaults to MinIO (minioadmin/minioadmin) if left blank.
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your_r2_access_key
STORAGE_SECRET_KEY=your_r2_secret_key
STORAGE_BUCKET=your-bucket
STORAGE_REGION=auto

# ── PostHog (analytics) → storefront (PUBLIC_*) + notification-service ──
PUBLIC_POSTHOG_KEY=phc_your_project_key
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_API_KEY=phx_your_personal_key
POSTHOG_HOST=https://eu.i.posthog.com

# ── Chatwoot (live chat, self-hosted in compose) ──────────────────────
PUBLIC_CHATWOOT_BASE_URL=http://localhost:3003
# Website inbox token — created inside Chatwoot after first-boot onboarding (Inbox → Website).
PUBLIC_CHATWOOT_WEBSITE_TOKEN=your_website_inbox_token
# Server secrets (storefront + notification-service):
CHATWOOT_HMAC_TOKEN=your_inbox_hmac_token
CHATWOOT_WEBHOOK_TOKEN=change-me-chatwoot-webhook
# Chatwoot's own service secrets (self-host). Generate SECRET_KEY_BASE with `openssl rand -hex 64`.
CHATWOOT_SECRET_KEY_BASE=change-me-secret-key-base
CHATWOOT_DB_PASSWORD=change-me-chatwoot-db

# ── Cloudflare CDN / public HTTPS → storefront ─────────────────────────
# Storefront host port (container is always 3000). Override to avoid a host clash.
STOREFRONT_HOST_PORT=3000
STOREFRONT_ORIGIN=http://localhost:3000

# ── Payload CMS ────────────────────────────────────────────────────────
# Generate with `openssl rand -hex 32`.
PAYLOAD_SECRET=change-me-payload-secret
