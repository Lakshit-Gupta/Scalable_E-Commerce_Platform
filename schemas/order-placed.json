{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ecommerce/schemas/order-placed.json",
  "title": "order.placed",
  "description": "Domain event emitted to ecommerce.order-events when an order is confirmed. Produced by the order-service outbox (Debezium EventRouter). The registry enforces BACKWARD compatibility on new versions.",
  "type": "object",
  "required": ["orderId", "userId", "status", "productIds"],
  "additionalProperties": true,
  "properties": {
    "orderId":    { "type": "string", "description": "UUID of the order" },
    "userId":     { "type": "string", "description": "Keycloak subject" },
    "totalAmount":{ "type": ["number", "string"], "description": "decimal, may serialize as string" },
    "status":     { "type": "string", "enum": ["CONFIRMED", "PENDING", "CANCELLED"] },
    "productIds": { "type": "array", "items": { "type": "string" } },
    "placedAt":   { "type": "string", "description": "ISO-8601 instant" }
  }
}
